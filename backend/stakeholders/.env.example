# Copy this file to .env and fill in the values:
#   cp .env.example .env

# PostgreSQL credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=microtourist-stakeholders

# Token signing secret — use a long random string in production
# Generate one with: openssl rand -hex 32
TOKEN_SECRET=

# Port the service is exposed on the host
PORT=8080
